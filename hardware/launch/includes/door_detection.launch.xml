 <launch>
  <node pkg="door_detection" type="door_detection" name="door_detection" launch-prefix="xterm -hold -e" >
    <param name="door_detection/MIN_DOOR_HEIGHT" value="1.95"/>
    <param name="door_detection/MAX_DOOR_HEIGHT" value="2.05"/>
    <param name="door_detection/OCC_RES" value="50.0"/>
    <param name="door_detection/FILL_THRESH" value="0.8"/>
    <param name="door_detection/MIN_WIDTH" value="0.6"/>
    <param name="door_detection/MIN_DEPTH" value="0.1"/>
    <param name="door_detection/MAX_DEPTH" value="0.5"/>
    <param name="door_detection/LASER_IN_DOOR_NARROWING_FACTOR" value="0.8"/>
    <param name="door_detection/LASER_IN_FRONT_OF_DOOR_NARROWING_FACTOR" value="0.5"/>
    <param name="door_detection/LASER_IN_FRONT_OF_DOOR_DEPTH_AREA" value="0.3"/>
    <param name="door_detection/MAX_LASER_IN_ZONE" value="5"/>
    <param name="door_detection/LASER_DOORFRAME_WIDTH" value="0.3"/>
    <param name="door_detection/LASER_DOORFRAME_DEPTH" value="0.1"/>
    <param name="door_detection/MIN_LASER_IN_DOORFRAME" value="50"/>
    <param name="door_detection/RATE" value="10"/>
    <param name="door_detection/MIN_ANGLE_DIFF" value="0.05"/>
    <param name="door_detection/MIN_DIST_DIFF" value="0.05"/>
    <param name="door_detection/MAX_DISCARD_TIME" value="2.0"/>
  </node>
</launch>
