<launch>
  <include file="$(find hardware)/launch/multimapping_3dgmapping.launch">
    <arg name="use_manual_control" value="0"/>
  </include>

 <node pkg="frontier_exploration" type="explore_client" name="explore_client" output="screen"/>

  <node pkg="frontier_exploration" type="explore_server" name="explore_server" output="screen">
    <param name="frequency" value="1.0"/>

    <!-- Should be less than sensor range -->
    <param name="goal_aliasing" value="2.0"/>

    <rosparam file="$(find hardware)/param/costmap_common_params.yaml" command="load" ns="explore_costmap" />
    <rosparam file="$(find hardware)/param/costmap_exploration_params.yaml" command="load" ns="explore_costmap" />
  </node>

</launch>
