<!-- launches turtlebot
-->
<launch>
  <arg name="move_file" default="xbox360_teleop.launch" doc="movement launch file"/>

  <include file="$(find hardware)/launch/turtlebot.launch">
    <arg name="3d_sensor" value="own_sensors"/>
  </include>

  <node name="set_z_scaling" pkg="dynamic_reconfigure" type="dynparam" args="set /camera/driver z_scaling 1.05" />

  <include file="$(find openni2_launch)/launch/openni2.launch">
    <arg name="depth_registration" value="true"/>
  </include>

  <node name="laser_scanner_node" pkg="hokuyo_node" type="hokuyo_node" required="true" launch-prefix="xterm -hold -e">
    <param name="port" value="/dev/ttyACM0"/>
    <param name="frame_id" value="laser_link"/>
    <param name="calibrate_time" type="bool" value="true"/>  
    <param name="intensity" type="bool" value="false"/>
    <param name="min_ang" value="-2.356194437"/>   
    <param name="max_ang" value="2.35619443"/>    
    <param name="cluster" value="1"/>
  </node>
  
  <include file="$(find turtlebot_teleop)/launch/$(arg move_file)">
  </include>

</launch>
