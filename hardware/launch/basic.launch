<!-- launches turtlebot
-->
<launch>
  <arg name="move_file" default="xbox360_teleop.launch" doc="movement launch file"/>
  <arg name="use_manual_control" default="0" doc="if manual control (keyboard/gamepad) is used"/>
  <arg name="use_mouse_control" default="0" doc="if manual control with mouse is used"/>
  <arg name="use_move_base" default="1" doc="if move_base used"/>

  <include file="$(find hardware)/launch/turtlebot.launch">
    <arg name="3d_sensor" value="own_sensors"/>
  </include>

  <include file="$(find openni2_launch)/launch/openni2.launch">
    <arg name="depth_registration" value="true"/>
      <arg name="device_id" value="#1" />
    <!--  <arg name="respawn" value="true" /> -->
  </include>

  <group ns="door_asus">
    <include file="$(find openni2_launch)/launch/openni2_tf_prefix.launch">
      <arg name="depth_registration" value="false"/>
      <arg name="depth_registered_processing" value="false"/>
      <arg name="rgb_processing" value="false"/>
      <arg name="debayer_processing" value="false"/>
      <arg name="device_id" value="#2" />
      <arg name="tf_prefix" value="door_asus" />
      <arg name="auto_exposure" value="false" />
      <arg name="auto_white_balance" value="false" />
    <!--  <arg name="respawn" value="true" /> -->
    </include>
  </group>

  <node name="set_z_scaling" pkg="dynamic_reconfigure" type="dynparam" args="set /camera/driver z_scaling 1.05" />
  <node name="set_frame_skip" pkg="dynamic_reconfigure" type="dynparam" args="set /camera/driver data_skip 6" />
<!--  <node name="door_asus_set_z_scaling" pkg="dynamic_reconfigure" type="dynparam" args="set /door_asus/camera/driver z_scaling 1.005" /> -->
  <node name="door_asus_set_frame_skip" pkg="dynamic_reconfigure" type="dynparam" args="set /door_asus/camera/driver data_skip 6" />

  <node name="laser_scanner_node" pkg="hokuyo_node" type="hokuyo_node" required="true">
    <param name="port" value="/dev/ttyACM0"/>
    <param name="frame_id" value="base_laser_link"/>
    <param name="calibrate_time" type="bool" value="true"/>  
    <param name="intensity" type="bool" value="false"/>
    <param name="min_ang" value="-2.356194437"/>   
    <param name="max_ang" value="2.35619443"/>    
    <param name="cluster" value="1"/>
  </node>

  <node pkg="my_laser_filter" type="my_laser_filter" name="my_laser_filter" args="-1.95 1.95" />  
  <node pkg="costmap_laser_node" type="costmap_laser_node" name="costmap_laser_node" args="-1.95 1.95 0.1 1.0 4.0" /> 

  <group if="$(arg use_manual_control)">    
    <include file="$(find turtlebot_teleop)/launch/$(arg move_file)">
    </include>
  </group>

  <group if="$(arg use_mouse_control)">    
    <include file="$(find mouse_control)/launch/mouse_control.launch" >
    </include>
  </group>

  <group if="$(arg use_move_base)">
    <include file="$(find hardware)/launch/includes/move_base.launch.xml"  >
      <arg name="laser_topic" value="scan_costmap" />
    </include>
  </group>

</launch>
