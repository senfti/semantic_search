<!-- launches turtlebot for mapping-->
<launch>
  <arg name="use_manual_control" default="1" doc="if manual control (keyboard/gamepad) is used"/>

  <include file="$(find hardware)/launch/basic.launch">
    <arg name="move_file" value="xbox360_teleop.launch"/>
    <arg name="use_manual_control" value="$(arg use_manual_control)"/>
  </include>

  <node pkg="tf" type="static_transform_publisher" name="base_footprint_to_base_link" args="0 0 0 0 0 0  /base_footprint /base_link 100" />

  <include file="$(find turtlebot_navigation)/launch/includes/move_base.launch.xml" />

  <node pkg="topic_tools" type="relay" name="odom_relay" args="/odom /rtabmap/odom" />
  <node pkg="topic_tools" type="relay" name="scan_relay" args="/scan /rtabmap/scan" />
  <node pkg="topic_tools" type="relay" name="rgb_relay" args="/camera/rgb/image_raw /rtabmap/rgb/image" />
  <node pkg="topic_tools" type="relay" name="info_relay" args="/camera/depth_registered/image_raw /rtabmap/depth/image" />
  <node pkg="topic_tools" type="relay" name="depth_relay" args="/camera/rgb/camera_info /rtabmap/rgb/camera_info" />

  <group ns="rtabmap">
    <node name="rtabmap" pkg="rtabmap_ros" type="rtabmap" output="screen" args="--delete_db_on_start">
          <param name="frame_id" type="string" value="base_link"/>

          <param name="subscribe_depth" type="bool" value="true"/>
          <param name="subscribe_scan" type="bool" value="true"/>

          <param name="queue_size" type="int" value="10"/>

          <!-- RTAB-Map's parameters -->
          <param name="RGBD/NeighborLinkRefining" type="string" value="true"/>
          <param name="RGBD/ProximityBySpace"     type="string" value="true"/>
          <param name="RGBD/AngularUpdate"        type="string" value="0.1"/>
          <param name="RGBD/LinearUpdate"         type="string" value="0.1"/>
          <param name="RGBD/OptimizeFromGraphEnd" type="string" value="false"/>
          <param name="Optimizer/Slam2D"          type="string" value="true"/>
          <param name="Reg/Strategy"              type="string" value="1"/> <!-- 1=ICP -->
          <param name="Reg/Force3DoF"             type="string" value="true"/>
          <param name="Vis/MinInliers"            type="string" value="5"/>
          <param name="Vis/InlierDistance"        type="string" value="0.1"/>
          <param name="Rtabmap/TimeThr"           type="string" value="700"/>
          <param name="Mem/RehearsalSimilarity"   type="string" value="0.45"/>
    </node>
  </group>

</launch>
