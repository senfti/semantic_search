<launch>
  <group ns="door_asus">
    <include file="$(find openni2_launch)/launch/openni2_tf_prefix.launch">
      <arg name="depth_registration" value="false"/>
      <arg name="depth_registered_processing" value="false"/>
      <arg name="rgb_processing" value="false"/>
      <arg name="debayer_processing" value="false"/>
      <arg name="device_id" value="#2" />
      <arg name="tf_prefix" value="door_asus" />
      <arg name="auto_exposure" value="false" />
      <arg name="auto_white_balance" value="false" />
    <!--  <arg name="respawn" value="true" /> -->
    </include>
  </group>

  <node pkg="my_laser_filter" type="my_laser_filter" name="my_laser_filter" args="-1.95 1.95" />  
  <node pkg="costmap_laser_node" type="costmap_laser_node" name="costmap_laser_node" args="-1.95 1.95 0.1 1.0 4.01" /> 
  
</launch>
