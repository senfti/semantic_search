<launch>
  
  <include file="$(find hardware)/launch/includes/robot.launch.xml">
    <arg name="base" value="$(env TURTLEBOT_BASE)" />
    <arg name="stacks" value="$(env TURTLEBOT_STACKS)" />
    <arg name="3d_sensor" value="own_sensors" />
  </include>


  <include file="$(find openni2_launch)/launch/openni2.launch">
    <arg name="depth_registration" value="true"/>
    <arg name="device_id" value="#1" />
  </include>

  <group ns="door_asus">
    <include file="$(find openni2_launch)/launch/openni2_tf_prefix.launch">
      <arg name="depth_registration" value="true"/>
      <arg name="device_id" value="#2" />
      <arg name="tf_prefix" value="door_asus" />
    </include>
  </group>

  <node name="set_z_scaling" pkg="dynamic_reconfigure" type="dynparam" args="set /camera/driver z_scaling 1.05" />
  <node name="door_asus_set_z_scaling" pkg="dynamic_reconfigure" type="dynparam" args="set /door_asus/camera/driver z_scaling 1.03" />

</launch>
