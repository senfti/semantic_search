<launch>
  <include file="$(find hardware)/launch/mapping_rosbag.launch">
  </include>

  <include file="$(find hardware)/launch/includes/robot.launch.xml">
    <arg name="base" value="$(env TURTLEBOT_BASE)" />
    <arg name="stacks" value="$(env TURTLEBOT_STACKS)" />
    <arg name="3d_sensor" value="own_sensors" />
  </include>
  
  <node pkg="octomap_server" type="octomap_server_node" name="octomap_server">
    <param name="resolution" value="0.05" />    
    <param name="frame_id" type="string" value="map" />                 <!-- fixed map frame (set to 'map' if SLAM or localization running!) -->    
    <param name="sensor_model/max_range" value="4.0" />                 <!-- maximum range to integrate (speedup!) -->    
    <param name="pointcloud_min_z" value="0.2" />                       <!-- maximum range to integrate (speedup!) -->    

    <remap from="cloud_in" to="/camera/depth_registered/points" />	    <!-- data source to integrate (PointCloud2) -->
  </node>

</launch>
